<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="350"
             xmlns:vm="clr-namespace:GameTrackerApp.ViewModels"
             x:Class="GameTrackerApp.Views.SessionFormView"
             x:DataType="vm:SessionFormViewModel">

  <StackPanel Margin="20" Spacing="10">
    <TextBlock Text="Formulář relace" FontSize="18" FontWeight="Bold" Margin="0,0,0,10" />

    <TextBlock Text="Datum:" />
    <DatePicker SelectedDate="{Binding DatePlayed}" />

    <TextBlock Text="Hodin hraní:" />
    <NumericUpDown Value="{Binding HoursPlayed}"
                   Minimum="0.1"
                   Maximum="24"
                   Increment="0.5"
                   FormatString="0.0" />

    <TextBlock Text="{Binding ErrorMessage}"
               Foreground="Red"
               FontWeight="Bold"
               IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
    <TextBlock Text="{Binding StatusMessage}" Foreground="Gray" />

    <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,15,0,0">
      <Button Content="Uložit" Command="{Binding SaveCommand}" />
      <Button Content="Zpět" Command="{Binding BackCommand}" />
    </StackPanel>
  </StackPanel>
</UserControl>
