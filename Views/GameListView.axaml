<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:vm="clr-namespace:GameTrackerApp.ViewModels"
             x:Class="GameTrackerApp.Views.GameListView"
             x:DataType="vm:GameListViewModel">

  <DockPanel LastChildFill="True" Margin="10">
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="10" Margin="0,0,0,5">
      <Button Content="Refresh" Command="{Binding RefreshCommand}" />
      <Button Content="Přidat hru" Command="{Binding AddCommand}" />
      <Button Content="Smazat hru" Command="{Binding DeleteCommand}" />
      <Button Content="Detail" Command="{Binding DetailCommand}" />
    </StackPanel>
    <TextBlock DockPanel.Dock="Top" Text="{Binding StatusMessage}" Foreground="Gray" Margin="0,0,0,5" />

    <ListBox ItemsSource="{Binding Games}"
             SelectedItem="{Binding SelectedGame}"
             MinHeight="200">
      <ListBox.ItemTemplate>
        <DataTemplate>
          <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Text="{Binding Id}" Width="40" />
            <TextBlock Text="{Binding Title}" Width="200" />
            <TextBlock Text="{Binding Developer}" Width="150" />
            <TextBlock Text="{Binding ReleaseYear}" Width="80" />
            <TextBlock Text="{Binding PlatformName}" Width="100" />
          </StackPanel>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
  </DockPanel>
</UserControl>
